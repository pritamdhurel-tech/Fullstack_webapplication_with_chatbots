# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# PostgreSQL connection string from Neon dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# JWT — generate a long random string for production
JWT_SECRET="replace_this_with_a_long_random_secret_string"
JWT_EXPIRES_IN="8h"

# Admin credentials — used for seeding the initial admin account
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@ai-solutions.co.uk"
ADMIN_PASSWORD="replace_with_secure_password"

# Nodemailer — Gmail SMTP (use an App Password, not your real Gmail password)
# Guide: https://support.google.com/accounts/answer/185833
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_gmail@gmail.com"
SMTP_PASS="your_gmail_app_password"
ADMIN_EMAIL_RECIPIENT="admin@ai-solutions.co.uk"

# Cloudinary — for gallery image uploads (free tier)
# Get from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Server
PORT=5000
NODE_ENV=development

# Frontend URL — used for CORS (update when deployed to Vercel)
CLIENT_URL="http://localhost:5173/"
